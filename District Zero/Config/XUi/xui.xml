<Zilox>

<!--  // Z2 HUD SCALE -->

	<set xpath="//ruleset/@stackpanel_scale">.89</set>

<!--	// Z2 // Compass -->

		<remove xpath="//window_group[@name='compass']/window"/>
		<append xpath="//window_group[@name='compass']">
			<window name="windowCompass" anchor="CenterTop" />	
			<window name="windowTargetBar" anchor="CenterTop" />
			<window name="onScreenIcons" />
			<window name="dayTimeHUD" anchor="LeftTop" />
		</append>

		<setattribute xpath="//window_group[@name='compass']" name="actionSet">false</setattribute>

<!--	// Z2 // Interaction -->
		
		<remove xpath="//window_group[@name='interactionPrompt']/window"/>
		<append xpath="//window_group[@name='interactionPrompt']">
			<window name="interactionPrompt" />
		</append>		

		<setattribute xpath="//window_group[@name='interactionPrompt']" name="actionSet">false</setattribute>


<!--	// Z2 // Search Timer -->

		<remove xpath="//window_group[@name='timer']/window"/>
		<append xpath="//window_group[@name='timer']">
			<window name="windowTimer" />
		</append>		


<!--	// Z2 // Throw Power -->
		
		<remove xpath="//window_group[@name='throwpower']/window"/>
		<append xpath="//window_group[@name='throwpower']">
			<window name="windowThrow" />
		</append>		

		<setattribute xpath="//window_group[@name='throwpower']" name="actionSet">false</setattribute>


<!--	// Z2 // Toolbelt -->
		
		<remove xpath="//window_group[@name='toolbelt']/window"/>
		<append xpath="//window_group[@name='toolbelt']">
			<window name="windowToolbelt" anchor="CenterBottom" />
			<window name="HUDLeftStatBars" anchor="LeftBottom" />
			<window name="HUDRightStatBars" anchor="RightBottom" />
			<window name="windowLocation" anchor="RightTop" />			
			<window name="windowQuestTracker" anchor="RightTop" />
			<window name="windowRecipeTracker" anchor="RightTop" />
			<window name="windowGroupBars" anchor="LeftTop" />
		</append>		

<!--	// Z2 // Radial Menu -->
		
		<remove xpath="//window_group[@name='radial']/window"/>
		<append xpath="//window_group[@name='radial']">
			<window name="windowRadial" />
		</append>		

		<setattribute xpath="//window_group[@name='radial']" name="actionSet">keyboard</setattribute>
		<setattribute xpath="//window_group[@name='radial']" name="controller">Radial</setattribute>

<!--	// Z2 // Chat Output -->
		
		<remove xpath="//window_group[@name='chatoutput']/window"/>
		<append xpath="//window_group[@name='chatoutput']">
			<window name="chatoutput" />
		</append>		

		<setattribute xpath="//window_group[@name='chatoutput']" name="actionSet">false</setattribute>

<!--	// Z2 // Chat Input -->
		
		<remove xpath="//window_group[@name='chat']/window"/>
		<append xpath="//window_group[@name='chat']">
			<window name="chat" />
		</append>		

<!--	// Z2 // Day / Time UI Inject -->

		<append xpath="/xui/ruleset[@name='default']/window_group[@name='crafting']">
			<window name="dayTimeUI" anchor="LeftTop" />
		</append>

		<append xpath="/xui/ruleset[@name='default']/window_group[@name='character']">
			<window name="dayTimeUI" anchor="LeftTop" />
		</append>

		<append xpath="/xui/ruleset[@name='default']/window_group[@name='map']">
			<window name="dayTimeUI" anchor="LeftTop" />
		</append>

		<append xpath="/xui/ruleset[@name='default']/window_group[@name='skills']">
			<window name="dayTimeUI" anchor="LeftTop" />
		</append>

		<append xpath="/xui/ruleset[@name='default']/window_group[@name='players']">
			<window name="dayTimeUI" anchor="LeftTop" />
		</append>

		<append xpath="/xui/ruleset[@name='default']/window_group[@name='quests']">
			<window name="dayTimeUI" anchor="LeftTop" />
		</append>

		<append xpath="/xui/ruleset[@name='default']/window_group[@name='creative']">
			<window name="dayTimeUI" anchor="LeftTop" />
		</append>

		<append xpath="/xui/ruleset[@name='default']/window_group[@name='looting']">
			<window name="dayTimeUI" anchor="LeftTop" />
		</append>

		<append xpath="/xui/ruleset[@name='default']/window_group[contains (@name, 'workstation')]">
			<window name="dayTimeUI" anchor="LeftTop" />
		</append>

		<append xpath="/xui/ruleset[@name='default']/window_group[@name='vehicle']">
			<window name="dayTimeUI" anchor="LeftTop" />
		</append>

		<append xpath="/xui/ruleset[@name='default']/window_group[@name='vehicleStorage']">
			<window name="dayTimeUI" anchor="LeftTop" />
		</append>

		<append xpath="/xui/ruleset[@name='default']/window_group[@name='assemble']">
			<window name="dayTimeUI" anchor="LeftTop" />
		</append>

		<append xpath="/xui/ruleset[@name='default']/window_group[@name='trader']">
			<window name="dayTimeUI" anchor="LeftTop" />
		</append>

		<append xpath="/xui/ruleset[@name='default']/window_group[@name='questTurnIn']">
			<window name="dayTimeUI" anchor="LeftTop" />
		</append>

		<append xpath="/xui/ruleset[@name='default']/window_group[@name='powersource']">
			<window name="dayTimeUI" anchor="LeftTop" />
		</append>

		<append xpath="/xui/ruleset[@name='default']/window_group[@name='powertrigger']">
			<window name="dayTimeUI" anchor="LeftTop" />
		</append>

		<append xpath="/xui/ruleset[@name='default']/window_group[@name='powerrangedtrap']">
			<window name="dayTimeUI" anchor="LeftTop" />
		</append>

		<append xpath="/xui/ruleset[@name='default']/window_group[@name='powercamera']">
			<window name="dayTimeUI" anchor="LeftTop" />
		</append>

		<append xpath="/xui/ruleset[@name='default']/window_group[@name='powerspotlight']">
			<window name="dayTimeUI" anchor="LeftTop" />
		</append>

<!--	// Z2 // In-Game Clean Menu -->

		<append xpath="//window_group[@name='ingameMenu']">
			<window name="cleanMenuBackground" />
		</append>

		<setattribute xpath="//window_group[@name='ingameMenu']" name="close_compass_on_open">true</setattribute>

<append xpath="/xui/ruleset">

		<window_group name="workstation_blastFurnace" controller="XUiC_WorkstationWindowGroup" open_backpack_on_open="true" close_compass_on_open="true">
			<window name="windowCraftingList"/>
			<window name="craftingInfoPanel"/>
			<window name="windowCraftingQueue"/>
			<window name="windowToolsBlastFurnace" />
			<window name="windowFuelBlastFurnace" />
			<window name="windowInputBlastFurnace" />
			<window name="windowOutputBlastFurnace" />
			<window name="windowNonPagingHeader" />
		</window_group>
		
		<window_group name="workstation_fabricator" controller="XUiC_WorkstationWindowGroup" open_backpack_on_open="true" close_compass_on_open="true">
			<window name="windowCraftingList"/>
			<window name="craftingInfoPanel"/>
			<window name="windowCraftingQueue"/>
			<window name="windowOutput" />
			<window name="windowNonPagingHeader" />
		</window_group>		

		<window_group name="workstation_autoMiner" controller="XUiC_WorkstationWindowGroup" open_backpack_on_open="true" close_compass_on_open="true">
			<window name="windowCraftingList"/>
			<window name="craftingInfoPanel"/>
			<window name="windowCraftingQueue"/>
			<window name="windowOutput" />
			<window name="windowNonPagingHeader" />
		</window_group>		
		
</append>
</Zilox>