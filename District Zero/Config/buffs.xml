<Zilox>

<!-- ADJUST ENCUMBRANCE FOR BIGGER BACKPACK -->
<set xpath="//buff[@name='buffEncumberedInv']/effect_group/triggered_effect[@cvar='$encumbranceEffect'][@value='0.026']/@value">0.013</set>
<set xpath="//buff[@name='buffDrugSteroids']/effect_group/passive_effect[@name='CarryCapacity']/@value">96</set>

<!-- REMOVE NEWBIE BUFF -->
<remove xpath="//buff[@name='buffNewbieCoat']"/>

<!-- FIX: Add check to buffDukeNote to remove itself when note is read (since buffNewbieCoat was removed) -->
<append xpath="//buff[@name='buffDukeNote']/effect_group">
	<triggered_effect trigger="onSelfBuffUpdate" action="RemoveBuff" buff="buffDukeNote">
		<requirement name="CVarCompare" cvar=".dukeNoteRead" operation="Equals" value="1"/>
	</triggered_effect>
	<triggered_effect trigger="onSelfBuffUpdate" action="RemoveBuff" buff="buffDukeNote">
