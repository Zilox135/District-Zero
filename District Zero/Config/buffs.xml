<append xpath="/buffs">

<!-- RADATION BUFF -->
	<buff name="buffRadiationMain" hidden="true">	
		<damage_type value="radiation"/>
		<stack_type value="ignore"/>
		<duration value="0"/>
		<update_rate value="1"/>

		<!-- Radiation is fully %-based. radiationCounter is a float % value. Radiation kills when it reaches 100% -->
		<effect_group>
			<!-- $radiationMaxDuration defined in buffStatusCheck01 (7 hours) -->
			<triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$radiationMaxDuration" operation="set" value="25200">
				<requirement name="CVarCompare" cvar="$radiationMaxDuration" operation="Equals" value="0"/>
			</triggered_effect>


			<triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$radiationStage2Duration" operation="set" value="30"/> <!-- % of the full buff duration -->
			<triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$radiationStage3Duration" operation="set" value="60"/> <!-- % of the full buff duration -->

			<triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$radiationDisplayDivisor" operation="set" value="@$radiationMaxDuration"/>
			<triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$radiationDisplayDivisor" operation="divide" value="100"/>
				<!-- .radiationDisplayPerc = radiationCounter / $radiationDisplayDivisor -->
			<triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$radiationStage2Duration" operation="multiply" value="@$radiationDisplayDivisor"/>
			<triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$radiationStage3Duration" operation="multiply" value="@$radiationDisplayDivisor"/>

			<!-- cleanup -->
			<triggered_effect trigger="onSelfBuffRemove" action="ModifyCVar" cvar="radiationCounter" operation="set" value="0"/>
			<triggered_effect trigger="onSelfBuffRemove" action="ModifyCVar" cvar=".radiationDisplayPerc" operation="set" value="0"/>
			<triggered_effect trigger="onSelfBuffRemove" action="ModifyCVar" cvar="$radiationDisplayDivisor" operation="set" value="0"/>
			<triggered_effect trigger="onSelfBuffRemove" action="ModifyCVar" cvar="$radiationStage2Duration" operation="set" value="0"/>
			<triggered_effect trigger="onSelfBuffRemove" action="ModifyCVar" cvar="$radiationStage3Duration" operation="set" value="0"/>
		</effect_group>

		<effect_group name="main loop">
			<!-- Make sure it does not go above 100% -->
			<triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar="radiationCounter" operation="set" value="@$radiationMaxDuration">
				<requirement name="CVarCompare" cvar="radiationCounter" operation="GT" value="@$radiationMaxDuration"/>
			</triggered_effect>
		
			<triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar="radiationCounter" operation="add" value="2.75">
				<requirement name="!HasBuff" buff="buffRadiationProtection"/>				
				<requirement name="InBiome" biome="8"/>				
			</triggered_effect>

			<triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar="radiationCounter" operation="set" value="0">
				<requirement name="CVarCompare" cvar="radiationCounter" operation="LT" value="0"/>
			</triggered_effect>
		</effect_group>

		<effect_group name="shut down">
			<triggered_effect trigger="onSelfBuffUpdate" action="AddBuff" buff="buffRadiationMain">
				<requirement name="CVarCompare" cvar="radiationCounter" operation="LTE" value="0"/>
			</triggered_effect>
		</effect_group>

		<effect_group name="display % values">
			<triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar=".radiationDisplayPerc" operation="set" value="@radiationCounter"/>
			<triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar=".radiationDisplayPerc" operation="divide" value="@$radiationDisplayDivisor"/>
		</effect_group>

		<effect_group name="signaling buffs">

			<triggered_effect trigger="onSelfBuffUpdate" action="AddBuff" buff="buffRadiation01Untreated">
				<requirement name="!HasBuff" buff="buffRadiation01Untreated"/>									
				<requirement name="CVarCompare" cvar="radiationCounter" operation="GTE" value="0"/>
				<requirement name="CVarCompare" cvar="radiationCounter" operation="LT" value="@$radiationStage2Duration"/>
			</triggered_effect>

			<triggered_effect trigger="onSelfBuffUpdate" action="AddBuff" buff="buffRadiation02Untreated">
				<requirement name="!HasBuff" buff="buffRadiation02Untreated"/>														
				<requirement name="CVarCompare" cvar="radiationCounter" operation="GTE" value="@$radiationStage2Duration"/>
				<requirement name="CVarCompare" cvar="radiationCounter" operation="LT" value="@$radiationStage3Duration"/>
			</triggered_effect>

			<triggered_effect trigger="onSelfBuffUpdate" action="AddBuff" buff="buffRadiation03Untreated">
				<requirement name="!HasBuff" buff="buffRadiation03Untreated"/>														
				<requirement name="CVarCompare" cvar="radiationCounter" operation="GTE" value="@$radiationStage3Duration"/>
				<requirement name="CVarCompare" cvar="radiationCounter" operation="LT" value="@$radiationMaxDuration"/>
			</triggered_effect>

			<triggered_effect trigger="onSelfBuffUpdate" action="AddBuff" buff="buffRadiation04">
				<requirement name="CVarCompare" cvar="radiationCounter" operation="GTE" value="@$radiationMaxDuration"/>				
			</triggered_effect>			
		</effect_group>	
	</buff>

	<buff name="buffRadiationAddCure" hidden="true">
		<stack_type value="ignore"/>
		<duration value=".1"/>
		<effect_group>
			<triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$buffRadiationAddCurePerc" operation="multiply" value="@$radiationMaxDuration"/>
			<triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$buffRadiationAddCurePerc" operation="divide" value="100"/>

			<triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="radiationCounter" operation="subtract" value="@$buffRadiationAddCurePerc"/>
			<triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$buffRadiationAddCurePerc" operation="set" value="0"/>

			<triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="radiationCounter" operation="set" value="@$radiationMaxDuration">
				<requirement name="CVarCompare" cvar="radiationCounter" operation="GT" value="@$radiationMaxDuration"/>
			</triggered_effect>
			<triggered_effect trigger="onSelfBuffStart" action="AddBuff" buff="buffRadiationMain"/>			
		</effect_group>
	</buff>

	<buff name="buffRadiation01Untreated" hidden="true">
		<damage_type value="Disease"/>
		<stack_type value="ignore"/>
		<duration value="0"/>
		<display_value value=".radiationDisplayPerc"/>
		<display_value_key value="{0:0.0}%"/>
