<Zilox>

<!-- REMOVE HUNTERS JOUNRAL BOOK SERIES -->
<remove xpath="//item[starts-with(@name,'bookHuntingJournal')]"/>

<!-- REMOVE ATTRIBUTE ARMOR MODS -->
<remove xpath="//item[@name='modArmorPerception']"/>
<remove xpath="//item[@name='modArmorStrength']"/>
<remove xpath="//item[@name='modArmorFortitude']"/>
<remove xpath="//item[@name='modArmorAgility']"/>
<remove xpath="//item[@name='modArmorIntellect']"/>

<!-- SET TRADER PROTECTION (Set to true if you want traders to be protected) -->
<setattribute xpath="/traders" name="trader_protection">false</setattribute>

<!-- SET TRADER LAND CLAIM PLACEMENT RULES (Singleplayer or Multiplayer or both Singleplayer,Multiplayer) -->
<setattribute xpath="/traders" name="land_claim_placement">Singleplayer</setattribute>

<!-- REMOVE TRADER OPEN AND CLOSE TIMES -->
<removeattribute xpath="//@open_time" />
<removeattribute xpath="//@close_time" />

<insertAfter xpath="/traders/traderstage_templates/traderstage_template[@name='baseTier3']">
	<traderstage_template name="baseTier4"> <!-- Mech Tools|T4 Weapons -->
		<entry min="1" max="999999" quality="0"/> <!-- Fallback for items without quality -->
		<entry min="200" max="999999" quality="1"/>
		<entry min="200" max="999999" quality="2"/>
		<entry min="200" max="999999" quality="3"/>
		<entry min="200" max="999999" quality="4"/>
		<entry min="200" max="999999" quality="5"/>
	</traderstage_template>
</insertAfter>

<!-- midTier3 now exists in vanilla A22, so modify it instead of inserting -->
<set xpath="/traders/traderstage_templates/traderstage_template[@name='midTier3']/entry/@min">50</set>

<!-- TRADER GROUPS -->
<append xpath="//trader_item_group[@name='traderGeneral']">
	<item name="drugAntiRadiation" count="1,3" prob="0.5"/>
</append>

<append xpath="//trader_item_group[@name='rareMedicine']">
	<item name="drugAdvancedAntiRadiation" prob="0.1"/>
</append>

