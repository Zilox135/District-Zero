<Zilox>

<!-- ADD A TAG TO BLOCK REFLEX SIGHTS FROM BEING INSTALLED -->
<csv xpath="//item_modifier[@name='modGunReflexSight']/@blocked_tags" delim="," op="add">noHolosight</csv>

<!-- MAKE CIGAR MOD GRANT A POINT INTO MINER 69R -->
<set xpath="//item_modifier[@name='modArmorCigar']/effect_group/passive_effect[@tags='attStrength']/@name">PerkLevel</set>
<set xpath="//item_modifier[@name='modArmorCigar']/effect_group/passive_effect[@name='PerkLevel']/@tags">perkMiner69r</set>

<!-- REMOVE ATTRIBUTE ARMOR MODS -->
<remove xpath="//item_modifier[@name='modArmorPerception']"/>
<remove xpath="//item_modifier[@name='modArmorStrength']"/>
<remove xpath="//item_modifier[@name='modArmorFortitude']"/>
<remove xpath="//item_modifier[@name='modArmorAgility']"/>
<remove xpath="//item_modifier[@name='modArmorIntellect']"/>

<!-- ALLOW EXTERMINATOR MOD TO BE INSTALLED WITH RAD REMOVER -->
<set xpath="//item_modifier[@name='modGunMeleeTheHunter']/@modifier_tags">specialDamage1</set>

<!-- MAKE EXTERMINATOR MOD WORK FOR DROIDS AND MECHS ONLY -->
<set xpath="//item_modifier[@name='modGunMeleeTheHunter']/effect_group">			
	<passive_effect name="EntityDamage" operation="perc_add" value=".25">
		<requirement name="EntityTagCompare" target="other" tags="mech,droid"/>				
	</passive_effect>
</set>

<!-- HIDE IRON SIGHTS WHEN REFLEX SIGHT IS INSTALLED -->
<append xpath="//item_modifier[@name='modGunReflexSight']">
		<effect_group tiered="false" name="hide plasma shotgun iron sight">
			<requirement name="HoldingItemHasTags" tags="plasmaShotgunSight"/>
			<triggered_effect trigger="onSelfHoldingItemCreated" action="SetTransformActive" active="false" parent_transform="#HeldItemRoot" transform_path="Ironsight_Front"/>
		</effect_group>	
		
		<effect_group tiered="false" name="hide plasma assault rifle iron sight">
			<requirement name="HoldingItemHasTags" tags="plasmaARSight"/>
			<triggered_effect trigger="onSelfHoldingItemCreated" action="SetTransformActive" active="false" parent_transform="#HeldItemRoot" transform_path="IronSight"/>
			<triggered_effect trigger="onSelfHoldingItemCreated" action="SetTransformActive" active="false" parent_transform="#HeldItemRoot" transform_path="IronSight.001"/>	
			<triggered_effect trigger="onSelfHoldingItemCreated" action="SetTransformActive" active="false" parent_transform="#HeldItemRoot" transform_path="IronSight.002"/>			
		</effect_group>		
</append>

<append xpath="//item_modifier[@name='modGunReflexSight']">
