<Zilox>

<append xpath="/nav_object_classes">

<nav_object_class name="vehicleNavMaster">
	<property name="requirement_type" value="IsVehicleOwner" />

	<compass_settings>
		<property name="sprite_name" value="ui_game_symbol_bicycle"/>
		<property name="min_distance" value="0"/>
		<property name="max_distance" value="-1"/>
		<property name="max_scale_distance" value="1024"/>
		<property name="color" value="255,255,0,255"/>
		<property name="has_pulse" value="true"/>
		<property name="icon_clamped" value="false" />
	</compass_settings>

	<onscreen_settings>
		<property name="sprite_name" value="ui_game_symbol_bicycle"/>
		<property name="min_distance" value="0"/>
		<property name="max_distance" value="20"/>
		<property name="max_scale_distance" value="64"/>
		<property name="color" value="255,255,0,255"/>
		<property name="has_pulse" value="false"/>
	</onscreen_settings>
</nav_object_class>

<nav_object_class name="muscleCar" extends="vehicleNavMaster">
	<property name="requirement_type" value="IsVehicleOwner" />

	<compass_settings>
		<property name="sprite_name" value="ui_game_symbol_musclecar"/>
	</compass_settings>

	<onscreen_settings>
		<property name="sprite_name" value="ui_game_symbol_musclecar"/>
	</onscreen_settings>
</nav_object_class>

<nav_object_class name="pickupTruck" extends="vehicleNavMaster">
