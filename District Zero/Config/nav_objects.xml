	<compass_settings>
		<property name="sprite_name" value="ui_game_symbol_pickuptruck"/>
	</compass_settings>

	<onscreen_settings>
		<property name="sprite_name" value="ui_game_symbol_pickuptruck"/>
	</onscreen_settings>
</nav_object_class>

<nav_object_class name="sedan" extends="vehicleNavMaster">
	<property name="requirement_type" value="IsVehicleOwner" />

	<compass_settings>
		<property name="sprite_name" value="ui_game_symbol_sedan"/>
	</compass_settings>

	<onscreen_settings>
		<property name="sprite_name" value="ui_game_symbol_sedan"/>
	</onscreen_settings>
