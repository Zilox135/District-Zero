<nav_object_class name="flyingCar" extends="vehicleNavMaster">
	<property name="requirement_type" value="IsVehicleOwner" />

	<compass_settings>
		<property name="sprite_name" value="ui_game_symbol_flyingcar"/>
	</compass_settings>

	<onscreen_settings>
		<property name="sprite_name" value="ui_game_symbol_flyingcar"/>
	</onscreen_settings>
</nav_object_class>

		<nav_object_class name="no_weapon">
			<onscreen_settings>
				<property name="sprite_name" value="ui_game_symbol_no_weapons"/>
				<property name="min_distance" value="0"/>
				<property name="max_distance" value="200"/>
				<property name="text_type" value="SpawnName"/>
				<property name="use_head_offset" value="true"/>
				<property name="offset" value="0,2,0" />
			</onscreen_settings>
		</nav_object_class>
		
</append>		
</Zilox>