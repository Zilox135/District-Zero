<Zilox>

<!-- REMOVE STAY WITHIN REQUIREMENT FOR QUESTING -->
<remove xpath="//objective[@type='POIStayWithin']"/>
<remove xpath="//objective[@type='StayWithin']"/>

<!-- MAKE RESTORE POWER QUESTS WORK AT ALL TIMES OF THE DAY -->
<remove xpath="//quest[contains(@id,'restore_power')]/objective[@type='RallyPoint']/property[@name='allowed_start_hour']"/>
<remove xpath="//quest[contains(@id,'restore_power')]/objective[@type='RallyPoint']/property[@name='allowed_end_hour']"/>

<!-- MAKE ALL REWARDS RANDOM -->
<setattribute xpath="//quest[@id='quest_reward_any_zombie_slayer']//reward" name="isfixed">false</setattribute>
<setattribute xpath="//quest[@id='quest_reward_lumberjack_zombie_slayer']//reward" name="isfixed">false</setattribute>

<!-- REMOVE LEGENDARY PART REWARDS -->
<remove xpath="//reward[@id='resourceLegendaryParts']"/>

<!-- ADD ENERGY AMMO TO REWARDS -->
<append xpath="//quest[@id='quest_reward_any_zombie_slayer']">
	<reward type="Item" id="ammoNanoEnergyCell" ischosen="true" isfixed="false" value="300"/>
	<reward type="Item" id="ammoShotgunEnergyCell" ischosen="true" isfixed="false" value="150"/>
	<reward type="Item" id="ammoHeavyEnergyCell" ischosen="true" isfixed="false" value="150"/>
</append>

<append xpath="//quest[@id='quest_reward_lumberjack_zombie_slayer']">
	<reward type="Item" id="thrownGrenadeEMP" ischosen="true" isfixed="false" value="25"/>
	<reward type="Item" id="mineEMP" ischosen="true" isfixed="false" value="10"/>
</append>

<!-- REMOVE OLD REWARDS -->
<remove xpath="//quest[@id='quest_reward_mutated_zombie_slayer']//reward"/>

<!-- ADD NEW REWARDS -->
<append xpath="//quest[@id='quest_reward_mutated_zombie_slayer']">
	<reward type="Item" id="modArmorCustomizedFittings" ischosen="true" isfixed="true" value="1"/>
	<reward type="Item" id="modArmorPlatingReinforced" ischosen="true" isfixed="true" value="1"/>
	<reward type="Item" id="modArmorQuadStoragePocket" ischosen="true" isfixed="true" value="1"/>
	<reward type="Item" id="modArmorAdvancedMuffledConnectors" ischosen="true" isfixed="true" value="1"/>
	<reward type="Item" id="modArmorTreasureHunter" ischosen="true" isfixed="true" value="1"/>
</append>

<!-- SET AUTO TRACKING OF THE OPEN STARTER CAPSULE CHALLENGE AFTER TALKING TO THE TRADER -->
<set xpath="//quest[@id='quest_whiteRiverCitizen1']/action[@type='TrackChallenge']/property[@name='challenge']/@value">openStarterCapsule</set>

<!-- REMOVE unique_key property TO USE SIMPLE CLOSEST-POI LOGIC INSTEAD OF TraderArea VALIDATION -->
<!-- unique_key="traderquest" causes chooseBestTrader() to be used which requires registered TraderAreas -->
<remove xpath="//quest[@id='quest_whiteRiverCitizen1']/property[@name='unique_key']"/>

